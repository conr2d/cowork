{
	"$comment": "Single source of truth for Cowork error codes (v0.1). Rust: cowork-errors/build.rs codegens the Code enum from this file. TS: src/lib/errors imports it directly. Localized errors.<code>.{title,body} strings live in the Paraglide catalogs (messages/{en,ja,ko}.json) and are checked against this set by the 3-locale parity test (WP2-loc). Per-code schema: { kind, contextKeys }. `kind` drives UI treatment; `contextKeys` are the camelCase keys the envelope's `context` may carry for ICU interpolation. `stage` is NOT stored here — it is a runtime property of the envelope (the same code can fire at multiple stages).",
	"kinds": ["Blocker", "NeedsUserAction", "Transient", "Internal", "Cancelled"],
	"stages": ["preflight", "wsl-enable", "provision", "toolchain", "agent-install", "auth", "workspace", "done"],
	"codes": {
		"preflight.windows_build_unsupported": { "kind": "Blocker", "contextKeys": ["build", "minBuild"] },
		"preflight.arch_unsupported": { "kind": "Blocker", "contextKeys": ["arch"] },
		"preflight.virtualization_unsupported": { "kind": "Blocker", "contextKeys": [] },
		"preflight.virtualization_disabled": { "kind": "NeedsUserAction", "contextKeys": [] },
		"preflight.hypervisor_conflict": { "kind": "NeedsUserAction", "contextKeys": ["detail"] },
		"preflight.insufficient_disk": { "kind": "NeedsUserAction", "contextKeys": ["requiredBytes", "availableBytes"] },
		"preflight.elevation_unavailable": { "kind": "Blocker", "contextKeys": [] },
		"preflight.wsl_blocked_by_policy": { "kind": "Blocker", "contextKeys": ["detail"] },
		"preflight.store_disabled": { "kind": "NeedsUserAction", "contextKeys": [] },
		"preflight.controlled_folder_access": { "kind": "NeedsUserAction", "contextKeys": ["path"] },

		"wsl.feature_enable_failed": { "kind": "Internal", "contextKeys": ["feature"] },
		"wsl.install_failed": { "kind": "Transient", "contextKeys": ["exitCode"] },
