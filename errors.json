		"workspace.delete_failed": { "kind": "Internal", "contextKeys": ["slug"] },
		"workspace.open_files_failed": { "kind": "Internal", "contextKeys": ["slug"] },
		"workspace.metadata_io_failed": { "kind": "Internal", "contextKeys": ["op"] },
