		"host.wsl_not_found": { "kind": "Internal", "contextKeys": [] },
		"host.pty_spawn_failed": { "kind": "Internal", "contextKeys": ["detail"] },
		"host.pty_bridge_failed": { "kind": "Internal", "contextKeys": ["detail"] },
		"common.network_failed": { "kind": "Transient", "contextKeys": ["httpStatus"] },
		"common.proxy_tls_error": { "kind": "NeedsUserAction", "contextKeys": ["host"] },
		"protocol.version_mismatch": { "kind": "Internal", "contextKeys": ["hostVersion", "guestVersion"] },
		"protocol.parse_error": { "kind": "Internal", "contextKeys": ["line"] },
		"internal.unknown": { "kind": "Internal", "contextKeys": ["detail"] },
		"common.cancelled": { "kind": "Cancelled", "contextKeys": [] }
	}
}
