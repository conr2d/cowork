		"wsl.update_unsupported_inbox": { "kind": "NeedsUserAction", "contextKeys": [] },
		"wsl.version_too_old": { "kind": "NeedsUserAction", "contextKeys": ["version", "minVersion"] },
		"wsl.elevation_denied": { "kind": "NeedsUserAction", "contextKeys": [] },
		"wsl.reboot_required": { "kind": "NeedsUserAction", "contextKeys": [] },
		"host.resume_state_corrupt": { "kind": "Internal", "contextKeys": ["detail"] },
		"host.setup_marker_failed": { "kind": "Internal", "contextKeys": ["detail"] },

		"distro.install_failed": { "kind": "Transient", "contextKeys": ["exitCode"] },
		"distro.rootfs_fetch_failed": { "kind": "Transient", "contextKeys": ["url", "httpStatus"] },
		"distro.checksum_mismatch": { "kind": "Internal", "contextKeys": ["expected", "actual"] },
		"distro.import_failed": { "kind": "Internal", "contextKeys": ["exitCode"] },
		"distro.already_exists": { "kind": "NeedsUserAction", "contextKeys": ["name"] },
		"distro.user_create_failed": { "kind": "Internal", "contextKeys": ["detail"] },
		"distro.disk_full": { "kind": "NeedsUserAction", "contextKeys": ["requiredBytes", "availableBytes"] },
		"distro.unregister_failed": { "kind": "Internal", "contextKeys": ["exitCode"] },
		"guest.cli_inject_failed": { "kind": "Internal", "contextKeys": ["detail"] },
		"guest.cli_launch_failed": { "kind": "Internal", "contextKeys": ["detail"] },
		"guest.cli_crashed": { "kind": "Internal", "contextKeys": ["exitCode", "lastStage"] },

		"toolchain.prereq_apt_failed": { "kind": "Transient", "contextKeys": ["packages"] },
		"toolchain.brew_install_failed": { "kind": "Transient", "contextKeys": ["exitCode"] },
		"toolchain.mise_install_failed": { "kind": "Transient", "contextKeys": ["exitCode"] },
		"toolchain.node_install_failed": { "kind": "Transient", "contextKeys": ["version", "exitCode"] },
		"toolchain.shellrc_write_failed": { "kind": "Internal", "contextKeys": ["file"] },

		"agent.install_failed": { "kind": "Transient", "contextKeys": ["agent", "exitCode"] },
		"agent.installer_download_failed": { "kind": "Transient", "contextKeys": ["agent", "url", "httpStatus"] },
		"agent.installer_hang": { "kind": "Internal", "contextKeys": ["agent"] },
