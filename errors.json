		"agent.integrity_check_failed": { "kind": "Internal", "contextKeys": ["agent"] },

		"auth.login_failed": { "kind": "NeedsUserAction", "contextKeys": ["agent", "exitCode"] },
		"auth.login_timeout": { "kind": "NeedsUserAction", "contextKeys": ["agent"] },
		"auth.browser_launch_failed": { "kind": "NeedsUserAction", "contextKeys": ["agent"] },
		"auth.oauth_callback_failed": { "kind": "NeedsUserAction", "contextKeys": ["agent"] },
		"auth.agent_not_found": { "kind": "Internal", "contextKeys": ["agent"] },
		"auth.status_probe_failed": { "kind": "Internal", "contextKeys": ["agent"] },

		"workspace.invalid_name": { "kind": "NeedsUserAction", "contextKeys": ["name"] },
