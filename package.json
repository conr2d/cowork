{
	"name": "cowork",
	"version": "0.1.0-dev",
	"private": true,
	"type": "module",
	"description": "Cowork — Windows GUI tool for non-developers to use AI coding agents",
	"license": "Apache-2.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"check": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"pretest": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"test": "vitest run",
		"tauri": "tauri",
		"machine-translate": "inlang machine translate --project ./project.inlang"
	},
	"devDependencies": {
		"@eslint/js": "^9.14.0",
		"@inlang/paraglide-js": "^2.18.2",
		"@sveltejs/adapter-static": "^3.0.5",
		"@sveltejs/kit": "^2.8.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@tauri-apps/cli": "^2.1.0",
		"@types/node": "^22.9.0",
		"eslint": "^9.14.0",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^15.12.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.3.0",
		"prettier-plugin-svelte": "^4.0.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.1.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.6.0",
		"typescript-eslint": "^8.15.0",
		"vite": "^5.4.0",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.1.0",
		"@tauri-apps/plugin-fs": "^2.0.0",
		"@tauri-apps/plugin-opener": "^2.0.0",
		"@xterm/addon-canvas": "^0.7.0",
		"@xterm/addon-clipboard": "^0.1.0",
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/addon-unicode11": "^0.8.0",
		"@xterm/addon-web-links": "^0.11.0",
		"@xterm/addon-webgl": "^0.18.0",
		"@xterm/xterm": "^5.5.0",
		"layerchart": "^1.0.0",
		"lucide-svelte": "^0.460.0"
	},
	"packageManager": "pnpm@10.34.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"@tailwindcss/oxide"
		]
	}
}
