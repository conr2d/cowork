{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Cowork",
	"version": "0.1.0",
	"identifier": "com.cowork.app",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Cowork",
				"width": 1000,
				"height": 720,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"]
	}
}
